APP_ENV=local
MAX_UPLOAD_MB=10
OPENROUTER_API_KEY=sk-
GOOGLE_API_KEY=AI
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/gabrr_budget_dev

# Copy to `.env` in this directory. Local Postgres example (see plan).
DEFAULT_USER_ID=gabe
DEFAULT_ACCOUNT_ID=acct_1

# Local PDF storage (absolute or relative to cwd)
UPLOAD_DIR=data/uploads

# Normalizer agent (ADK /run)
AGENT_RUN_URL=http://127.0.0.1:8001/run
AGENT_APP_NAME=app
AGENT_DEFAULT_SESSION_ID=01
AGENT_HTTP_TIMEOUT_SECONDS=600
