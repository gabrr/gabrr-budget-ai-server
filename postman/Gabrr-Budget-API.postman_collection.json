{
  "info": {
    "name": "Gabrr Budget API",
    "description": "Local examples (transactions + stub categories). Set collection variables `host` / `port` if needed. Import: Postman → Import → this file.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "protocol", "value": "http" },
    { "key": "host", "value": "127.0.0.1" },
    { "key": "port", "value": "8000" },
    {
      "key": "transaction_id",
      "value": "tx_demo_market",
      "description": "Replace with an id from GET /transactions after seed or create."
    }
  ],
  "item": [
    {
      "name": "Transactions",
      "item": [
        {
          "name": "List transactions (paginated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/transactions?limit=5&offset=0",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["transactions"],
              "query": [
                { "key": "limit", "value": "5" },
                { "key": "offset", "value": "0" }
              ]
            },
            "description": "Matches curl smoke: GET with limit/offset."
          }
        },
        {
          "name": "List transactions (category=food)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/transactions?category=food&limit=50&offset=0",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["transactions"],
              "query": [
                { "key": "category", "value": "food" },
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "List transactions (date range)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/transactions?date_from=2026-05-01&date_to=2026-05-31&limit=50&offset=0",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["transactions"],
              "query": [
                { "key": "date_from", "value": "2026-05-01" },
                { "key": "date_to", "value": "2026-05-31" },
                { "key": "limit", "value": "50" },
                { "key": "offset", "value": "0" }
              ]
            }
          }
        },
        {
          "name": "Create transaction",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"posted_at\": \"2026-05-09\",\n  \"description\": \"Postman smoke\",\n  \"amount\": \"12.34\"\n}"
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/transactions",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["transactions"]
            },
            "description": "Server fills user_id/account_id from .env when omitted."
          }
        },
        {
          "name": "Bulk create transactions",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"transactions\": [\n    {\n      \"posted_at\": \"2026-05-09\",\n      \"description\": \"bulk a\",\n      \"amount\": \"1.00\"\n    },\n    {\n      \"posted_at\": \"2026-05-09\",\n      \"description\": \"bulk b\",\n      \"amount\": \"2.00\"\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/transactions/bulk",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["transactions", "bulk"]
            }
          }
        },
        {
          "name": "Get transaction by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/transactions/{{transaction_id}}",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["transactions", "{{transaction_id}}"]
            }
          }
        },
        {
          "name": "Patch transaction",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"description\": \"Updated via Postman\",\n  \"amount\": \"99.99\"\n}"
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/transactions/{{transaction_id}}",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["transactions", "{{transaction_id}}"]
            }
          }
        },
        {
          "name": "Delete transaction",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/transactions/{{transaction_id}}",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["transactions", "{{transaction_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Categories (stubs)",
      "description": "Not DB-backed yet.",
      "item": [
        {
          "name": "List categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/categories",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["categories"]
            }
          }
        },
        {
          "name": "Create category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"key\": \"food\",\n  \"name\": \"Food\"\n}"
            },
            "url": {
              "raw": "{{protocol}}://{{host}}:{{port}}/categories",
              "protocol": "{{protocol}}",
              "host": ["{{host}}"],
              "port": "{{port}}",
              "path": ["categories"]
            }
          }
        }
      ]
    }
  ]
}
